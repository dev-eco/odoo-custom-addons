<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar la vista de búsqueda del reporte de ventas -->
    <record id="view_sale_report_filter_inherit_material_planning" model="ir.ui.view">
        <field name="name">sale.report.search.inherit.material.planning</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_search"/>
        <field name="arch" type="xml">
            <search position="inside">
                <group expand="0" string="Planificación de Material">
                    <separator/>
                    <filter string="Urgentes" name="urgent_orders" 
                            domain="[('is_urgent', '=', True)]"/>
                    <filter string="Nuevos" name="new_status" 
                            domain="[('order_status', '=', 'new')]"/>
                    <filter string="En Almacén" name="warehouse_status" 
                            domain="[('order_status', '=', 'warehouse')]"/>
                    <filter string="En Fabricación" name="manufacturing_status" 
                            domain="[('order_status', '=', 'manufacturing')]"/>
                    <filter string="Preparados" name="prepared_status" 
                            domain="[('order_status', '=', 'prepared')]"/>
                    <filter string="Salida" name="shipped_status" 
                            domain="[('order_status', '=', 'shipped')]"/>
                    <separator/>
                    <filter string="Albarán No Creado" name="picking_not_created" 
                            domain="[('picking_status', '=', 'not_created')]"/>
                    <filter string="Albarán Realizado" name="picking_done" 
                            domain="[('picking_status', '=', 'done')]"/>
                </group>
                <group expand="0" string="Agrupar Por Material">
                    <filter string="Estado de Pedido" name="group_order_status" 
                            context="{'group_by': 'order_status'}"/>
                    <filter string="Estado de Albarán" name="group_picking_status" 
                            context="{'group_by': 'picking_status'}"/>
                    <filter string="Urgencia" name="group_urgent" 
                            context="{'group_by': 'is_urgent'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista de árbol personalizada para el reporte con campos de planificación -->
    <record id="sale_report_view_tree_material_planning" model="ir.ui.view">
        <field name="name">sale.report.tree.material.planning</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <tree string="Análisis de Ventas - Planificación Material" create="false">
                <field name="date" optional="show"/>
                <field name="name" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="product_id" optional="show"/>
                <field name="product_uom_qty" optional="show" sum="Total"/>
                <field name="qty_delivered" optional="hide"/>
                <field name="qty_invoiced" optional="hide"/>
                <field name="order_status" optional="show"
                       decoration-success="order_status == 'shipped'"
                       decoration-info="order_status == 'prepared'"
                       decoration-primary="order_status == 'manufacturing'"
                       decoration-warning="order_status == 'warehouse'"
                       decoration-muted="order_status == 'new'"/>
                <field name="is_urgent" optional="show" widget="boolean_toggle" 
                       decoration-danger="is_urgent == True"/>
                <field name="picking_status" optional="show" widget="badge"
                       decoration-success="picking_status == 'done'"
                       decoration-info="picking_status == 'assigned'"
                       decoration-warning="picking_status == 'partially_available'"
                       decoration-danger="picking_status in ['not_created', 'waiting']"/>
                <field name="price_total" optional="show" sum="Total"/>
                <field name="state" optional="hide"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Vista pivot personalizada -->
    <record id="sale_report_view_pivot_material_planning" model="ir.ui.view">
        <field name="name">sale.report.pivot.material.planning</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Ventas - Material" sample="1">
                <field name="product_id" type="row"/>
                <field name="order_status" type="col"/>
                <field name="product_uom_qty" type="measure"/>
                <field name="price_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Vista gráfica personalizada -->
    <record id="sale_report_view_graph_material_planning" model="ir.ui.view">
        <field name="name">sale.report.graph.material.planning</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <graph string="Análisis de Ventas - Material" sample="1">
                <field name="order_status"/>
                <field name="product_uom_qty" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Acción para abrir el reporte con vista de planificación -->
    <record id="action_sale_report_material_planning" model="ir.actions.act_window">
        <field name="name">Análisis de Ventas - Planificación Material</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">tree,pivot,graph</field>
        <field name="context">{
            'search_default_Sales': 1,
            'group_by': ['order_status']
        }</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('sale_report_view_tree_material_planning')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('sale_report_view_pivot_material_planning')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('sale_report_view_graph_material_planning')})]"/>
        <field name="search_view_id" ref="view_sale_report_filter_inherit_material_planning"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea un pedido de venta para analizar
            </p>
        </field>
    </record>

    <!-- Elemento de menú -->
    <menuitem id="menu_sale_report_material_planning"
              name="Análisis - Planificación Material"
              parent="sale.sale_order_menu"
              sequence="99"
              action="action_sale_report_material_planning"
              groups="sales_team.group_sale_salesman"/>
</odoo>

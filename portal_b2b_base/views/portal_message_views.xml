<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Vista de árbol para portal.message -->
        <record id="view_portal_message_tree" model="ir.ui.view">
            <field name="name">portal.message.tree</field>
            <field name="model">portal.message</field>
            <field name="arch" type="xml">
                <tree string="Mensajes">
                    <field name="subject"/>
                    <field name="partner_id"/>
                    <field name="sender_type"/>
                    <field name="priority"/>
                    <field name="is_read"/>
                    <field name="create_date"/>
                </tree>
            </field>
        </record>
        
        <!-- Vista de formulario para portal.message -->
        <record id="view_portal_message_form" model="ir.ui.view">
            <field name="name">portal.message.form</field>
            <field name="model">portal.message</field>
            <field name="arch" type="xml">
                <form string="Mensaje">
                    <header>
                        <button name="action_mark_read" type="object" string="Marcar como Leído" 
                                class="btn-primary" invisible="is_read"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="subject"/>
                            <field name="partner_id"/>
                            <field name="sender_type"/>
                            <field name="priority"/>
                            <field name="is_read"/>
                            <field name="read_date" invisible="not is_read"/>
                        </group>
                        <group>
                            <field name="message" nolabel="1"/>
                        </group>
                        <group string="Información Relacionada">
                            <field name="related_model"/>
                            <field name="related_id"/>
                            <field name="parent_id"/>
                        </group>
                        <group string="Adjuntos">
                            <field name="attachment_ids" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Acción para portal.message -->
        <record id="action_portal_message" model="ir.actions.act_window">
            <field name="name">Mensajes Portal</field>
            <field name="res_model">portal.message</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay mensajes
                </p>
            </field>
        </record>
        
        <!-- Menú para portal.message -->
        <menuitem id="menu_portal_message" name="Mensajes Portal" 
                  parent="base.menu_administration" action="action_portal_message"/>
        
    </data>
</odoo>

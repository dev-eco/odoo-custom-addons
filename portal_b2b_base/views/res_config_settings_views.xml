<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_portal_b2b" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.portal.b2b</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" data_key="portal_b2b_base" string="Portal B2B">
                    <h2>Portal B2B</h2>
                    <div class="row mt16 o_settings_container" id="portal_b2b_settings">
                        <div class="col-12 col-lg-6 o_setting_box" id="return_notification_setting">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="return_notification_email" string="Email para Notificaciones de Devolución"/>
                                <div class="text-muted">
                                    Email donde se enviarán las notificaciones de nuevas solicitudes de devolución
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="return_notification_email" 
                                               placeholder="pedidos@ecocaucho.info"
                                               class="oe_inline"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>

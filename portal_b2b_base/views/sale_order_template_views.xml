<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista árbol (lista) de plantillas -->
    <record id="view_sale_order_template_tree" model="ir.ui.view">
        <field name="name">sale.order.template.tree</field>
        <field name="model">sale.order.template</field>
        <field name="arch" type="xml">
            <tree string="Plantillas de Pedidos" edit="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="total_products" optional="show"/>
                <field name="estimated_total" widget="monetary" optional="show"/>
                <field name="use_count" optional="show"/>
                <field name="last_used_date" optional="hide"/>
                <field name="active" widget="boolean" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- Vista formulario de plantillas -->
    <record id="view_sale_order_template_form" model="ir.ui.view">
        <field name="name">sale.order.template.form</field>
        <field name="model">sale.order.template</field>
        <field name="arch" type="xml">
            <form string="Plantilla de Pedido">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_order_from_template" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-shopping-cart">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Crear</span>
                                <span class="o_stat_text">Pedido</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la Plantilla"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Información">
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="active" widget="boolean"/>
                        </group>
                        <group string="Estadísticas">
                            <field name="use_count" readonly="True"/>
                            <field name="last_used_date" readonly="True"/>
                            <field name="estimated_total" widget="monetary" readonly="True"/>
                        </group>
                    </group>

                    <group string="Configuración Predeterminada">
                        <field name="delivery_address_id" options="{'no_create': True}"/>
                        <field name="distributor_label_id" options="{'no_create': True}"/>
                    </group>

                    <notebook>
                        <page string="Productos" name="products">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="quantity"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Notas" name="notes">
                            <field name="notes" nolabel="1" placeholder="Notas adicionales..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción para gestionar plantillas -->
    <record id="action_sale_order_template" model="ir.actions.act_window">
        <field name="name">Plantillas de Pedidos</field>
        <field name="res_model">sale.order.template</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay plantillas de pedidos
            </p>
            <p>
                Las plantillas permiten crear pedidos recurrentes rápidamente.
                Cree una plantilla desde un pedido existente o cree una nueva manualmente.
            </p>
        </field>
    </record>

    <!-- Menú para plantillas -->
    <menuitem id="menu_sale_order_template"
              name="Plantillas de Pedidos"
              parent="sale.sale_menu_root"
              action="action_sale_order_template"
              sequence="10"/>

</odoo>

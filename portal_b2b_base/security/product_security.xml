<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Record Rule: Distribuidores ven productos en venta -->
        <!-- NOTA: El filtrado por categorías se hace en Python (get_allowed_product_domain) -->
        <!-- NO se usa en record rules para evitar dependencias de campos nuevos -->
        <record id="product_product_distributor_rule" model="ir.rule">
            <field name="name">Portal B2B: Productos disponibles para venta</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="domain_force">[
                ('sale_ok', '=', True),
                ('active', '=', True)
            ]</field>
            <field name="groups" eval="[(4, ref('portal_b2b_base.group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- Record Rule: Mismo para product.template -->
        <record id="product_template_distributor_rule" model="ir.rule">
            <field name="name">Portal B2B: Templates disponibles para venta</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="domain_force">[
                ('sale_ok', '=', True),
                ('active', '=', True)
            ]</field>
            <field name="groups" eval="[(4, ref('portal_b2b_base.group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- NOTA: Este archivo se carga DESPUÉS de que los campos existan -->
        <!-- Regla avanzada con categorías (se aplicará después) -->
        
        <record id="product_product_category_advanced_rule" model="ir.rule">
            <field name="name">Portal B2B: Filtro avanzado por categorías</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="domain_force">[
                '|',
                    ('categ_id', 'in', user.partner_id.allowed_product_categories.ids),
                    ('sale_ok', '=', True)
            ]</field>
            <field name="groups" eval="[(4, ref('portal_b2b_base.group_portal_b2b'))]"/>
            <field name="active" eval="False"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
    </data>
</odoo>

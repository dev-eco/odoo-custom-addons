<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <!-- Grupo Portal B2B -->
        <record id="group_portal_b2b" model="res.groups">
            <field name="name">Portal B2B Distribuidor</field>
            <field name="category_id" ref="base.module_category_sales_sales"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
            <field name="comment">Usuarios distribuidores con acceso al portal B2B. Se asigna automáticamente al crear usuario portal para distribuidores.</field>
        </record>

        <!-- Record Rules: Sale Order -->
        <record id="sale_order_portal_b2b_rule" model="ir.rule">
            <field name="name">Portal B2B: Ver solo pedidos propios</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record Rules: Account Move (Facturas) -->
        <record id="account_move_portal_b2b_rule" model="ir.rule">
            <field name="name">Portal B2B: Ver solo facturas propias</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="domain_force">[
                ('move_type', '=', 'out_invoice'),
                ('partner_id', 'child_of', [user.commercial_partner_id.id])
            ]</field>
            <field name="groups" eval="[(4, ref('group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record Rules: Stock Picking (Albaranes/Entregas) -->
        <record id="stock_picking_portal_b2b_rule" model="ir.rule">
            <field name="name">Portal B2B: Ver solo entregas propias</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force">[
                ('partner_id', 'child_of', [user.commercial_partner_id.id]),
                ('picking_type_code', '=', 'outgoing')
            ]</field>
            <field name="groups" eval="[(4, ref('group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record Rules: Product Product (solo lectura) -->
        <record id="product_product_portal_b2b_rule" model="ir.rule">
            <field name="name">Portal B2B: Ver productos en venta</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="domain_force">[('sale_ok', '=', True), ('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record Rules: Sale Order Template -->
        <record id="sale_order_template_portal_b2b_rule" model="ir.rule">
            <field name="name">Portal B2B: Ver solo plantillas propias</field>
            <field name="model_id" ref="portal_b2b_base.model_sale_order_template"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules: Sale Order Template Line -->
        <record id="sale_order_template_line_portal_b2b_rule" model="ir.rule">
            <field name="name">Portal B2B: Gestionar líneas de plantillas propias</field>
            <field name="model_id" ref="portal_b2b_base.model_sale_order_template_line"/>
            <field name="domain_force">[('template_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_portal_b2b'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista formulario del wizard -->
    <record id="view_sale_order_template_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.template.wizard.form</field>
        <field name="model">sale.order.template.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Plantilla desde Pedido">
                <group>
                    <field name="order_id" readonly="True"/>
                    <field name="template_name" placeholder="Ej: Pedido Mensual Almacén A"/>
                </group>

                <group string="Opciones">
                    <field name="include_notes"/>
                    <field name="include_delivery_address"/>
                    <field name="include_distributor_label"/>
                </group>

                <footer>
                    <button name="action_create_template" 
                            string="Crear Plantilla" 
                            type="object" 
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción del wizard -->
    <record id="action_sale_order_template_wizard" model="ir.actions.act_window">
        <field name="name">Crear Plantilla</field>
        <field name="res_model">sale.order.template.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>

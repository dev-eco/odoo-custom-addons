<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Configuración del Portal B2B en el Sitio Web -->
        <!-- RUTAS EN CASTELLANO - Editar desde Sitio Web > Configuración > Menús -->
        
        <!-- Menú principal -->
        <record id="menu_portal_b2b_header" model="website.menu">
            <field name="name">Mi Portal</field>
            <field name="url">/mi-portal</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">100</field>
            <field name="is_visible">True</field>
        </record>
        
        <!-- Submenú: Mis Pedidos -->
        <record id="menu_portal_b2b_orders" model="website.menu">
            <field name="name">Mis Pedidos</field>
            <field name="url">/mis-pedidos</field>
            <field name="parent_id" ref="menu_portal_b2b_header"/>
            <field name="sequence">10</field>
            <field name="is_visible">True</field>
        </record>
        
        <!-- Submenú: Crear Pedido -->
        <record id="menu_portal_b2b_create_order" model="website.menu">
            <field name="name">Crear Pedido</field>
            <field name="url">/crear-pedido</field>
            <field name="parent_id" ref="menu_portal_b2b_header"/>
            <field name="sequence">20</field>
            <field name="is_visible">True</field>
        </record>
        
        <!-- Submenú: Mis Facturas -->
        <record id="menu_portal_b2b_invoices" model="website.menu">
            <field name="name">Mis Facturas</field>
            <field name="url">/mis-facturas</field>
            <field name="parent_id" ref="menu_portal_b2b_header"/>
            <field name="sequence">30</field>
            <field name="is_visible">True</field>
        </record>
        
        <!-- Submenú: Mis Direcciones -->
        <record id="menu_portal_b2b_addresses" model="website.menu">
            <field name="name">Mis Direcciones</field>
            <field name="url">/mis-direcciones</field>
            <field name="parent_id" ref="menu_portal_b2b_header"/>
            <field name="sequence">40</field>
            <field name="is_visible">True</field>
        </record>
        
        <!-- Submenú: Etiquetas Cliente Final -->
        <record id="menu_portal_b2b_labels" model="website.menu">
            <field name="name">Etiquetas Cliente Final</field>
            <field name="url">/mis-etiquetas</field>
            <field name="parent_id" ref="menu_portal_b2b_header"/>
            <field name="sequence">50</field>
            <field name="is_visible">True</field>
        </record>
        
        <!-- Submenú: Mi Cuenta -->
        <record id="menu_portal_b2b_account" model="website.menu">
            <field name="name">Mi Cuenta</field>
            <field name="url">/mi-cuenta</field>
            <field name="parent_id" ref="menu_portal_b2b_header"/>
            <field name="sequence">60</field>
            <field name="is_visible">True</field>
        </record>
        
    </data>
</odoo>

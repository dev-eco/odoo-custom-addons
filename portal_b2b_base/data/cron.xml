<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron para crear pedidos recurrentes -->
        <record id="ir_cron_create_recurring_orders" model="ir.cron">
            <field name="name">Portal B2B: Crear Pedidos Recurrentes</field>
            <field name="model_id" ref="model_sale_order_template"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_recurring_orders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
    </data>
</odoo>

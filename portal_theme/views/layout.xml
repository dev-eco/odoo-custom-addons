<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Layout personalizado para portal B2B -->
    <template id="portal_theme_layout" name="Portal B2B Theme Layout" inherit_id="web.layout" priority="20">
        
        <!-- Agregar clase al body para estilos del tema -->
        <xpath expr="//body" position="attributes">
            <attribute name="class" add="portal-b2b-theme" separator=" "/>
        </xpath>
        
    </template>
    
    <!-- Personalización del portal layout -->
    <template id="portal_theme_portal_layout" name="Portal Theme - Portal Layout" inherit_id="portal.portal_layout" priority="20">
        
        <!-- Agregar clases personalizadas al contenedor principal -->
        <xpath expr="//div[hasclass('o_portal')]" position="attributes">
            <attribute name="class" add="portal-b2b-custom" separator=" "/>
        </xpath>
        
    </template>

</odoo>

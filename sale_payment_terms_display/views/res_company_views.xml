<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extensión de la vista de empresa -->
    <record id="view_company_form_payment_info" model="ir.ui.view">
        <field name="name">res.company.form.payment.info</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Información de Pago" name="payment_info">
                    <group>
                        <group string="Configuración Bancaria">
                            <field name="primary_bank_account"
                                   domain="[('company_id', '=', active_id)]"/>
                            <field name="bank_payment_reference_format"/>
                            <field name="bank_payment_instructions" widget="html"/>
                        </group>

                        <group string="Códigos QR">
                            <field name="enable_payment_qr"/>
                            <field name="qr_payment_concept"
                                   invisible="enable_payment_qr == False"/>
                        </group>
                    </group>

                    <group>
                        <group string="Descuentos por Pronto Pago">
                            <field name="enable_early_discount"/>
                            <field name="early_payment_discount_rate"
                                   invisible="enable_early_discount == False"/>
                            <field name="early_payment_days"
                                   invisible="enable_early_discount == False"/>
                        </group>

                        <group string="Configuración por Defecto">
                            <field name="show_bank_info_default"/>
                            <field name="show_payment_qr_default"/>
                            <field name="show_early_discount_default"/>
                        </group>
                    </group>

                    <group string="Términos y Condiciones">
                        <field name="payment_terms_note" widget="html" colspan="2"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>

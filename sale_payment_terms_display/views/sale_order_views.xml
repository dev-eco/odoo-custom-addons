<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extensión del formulario de pedidos de venta -->
    <record id="view_order_form_payment_info" model="ir.ui.view">
        <field name="name">sale.order.form.payment.info</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Añadir pestaña de información de pago -->
            <notebook position="inside">
                <page string="Información de Pago" name="payment_info">
                    <group>
                        <group string="Referencias y Configuración">
                            <field name="payment_reference" readonly="1"/>
                            <field name="payment_urgency"/>
                            <field name="bank_account_to_show" 
                                   domain="[('company_id', '=', company_id)]"/>
                        </group>
                        
                        <group string="Opciones de Visualización">
                            <field name="show_bank_info"/>
                            <field name="show_payment_qr"/>
                            <field name="show_early_discount"/>
                        </group>
                    </group>
                    
                    <group string="Métodos de Pago">
                        <field name="available_payment_methods" widget="many2many_tags"/>
                        <field name="preferred_payment_method"/>
                    </group>
                    
                    <group string="Descuento por Pronto Pago" 
                           invisible="show_early_discount == False">
                        <group>
                            <field name="early_payment_due_date" readonly="1"/>
                            <field name="early_payment_discount_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="early_payment_final_amount" readonly="1"/>
                        </group>
                    </group>
                    
                    <group string="Instrucciones Personalizadas">
                        <field name="custom_payment_instructions" widget="html" colspan="2"/>
                    </group>
                    
                    <group string="Código QR de Pago" 
                           invisible="show_payment_qr == False">
                        <field name="payment_qr_code" widget="image" readonly="1"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Vista tree para mostrar información de pago -->
    <record id="view_quotation_tree_payment_info" model="ir.ui.view">
        <field name="name">sale.order.tree.payment.info</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <field name="amount_total" position="after">
                <field name="payment_reference" optional="hide"/>
                <field name="payment_urgency" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>

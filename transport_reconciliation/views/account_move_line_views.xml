<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extensión de formulario de factura para líneas de transporte -->
        <record id="view_move_form_transport" model="ir.ui.view">
            <field name="name">account.move.form.transport</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='product_id']" position="after">
                    <field name="transport_carrier_id" optional="hide"/>
                    <field name="transport_reference" optional="hide"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

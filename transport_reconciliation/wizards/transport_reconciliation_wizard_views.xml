<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Formulario del Asistente de Conciliación -->
        <record id="transport_reconciliation_wizard_form" model="ir.ui.view">
            <field name="name">transport.reconciliation.wizard.form</field>
            <field name="model">transport.reconciliation.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="transport_carrier_id" required="1"/>
                        <field name="month" required="1"/>
                        <field name="year" required="1"/>
                        <field name="discrepancy_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Líneas de Conciliación">
                            <field name="wizard_line_ids">
                                <tree editable="bottom">
                                    <field name="picking_number" readonly="1"/>
                                    <field name="expected_cost" readonly="1"/>
                                    <field name="invoiced_cost"/>
                                    <field name="has_discrepancy" readonly="1"/>
                                    <field name="discrepancy_amount" readonly="1"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_reconcile" string="Conciliar" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción para abrir el asistente -->
        <record id="action_transport_reconciliation_wizard" model="ir.actions.act_window">
            <field name="name">Conciliación de Transportes</field>
            <field name="res_model">transport.reconciliation.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>

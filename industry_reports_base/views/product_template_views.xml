<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extensión de la vista form de product.template -->
    <record id="product_template_form_view_dimensions" model="ir.ui.view">
        <field name="name">product.template.form.dimensions</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Añadir group "Dimensiones" en el notebook "Inventory" existente -->
            <xpath expr="//page[@name='inventory']" position="inside">
                <group string="Dimensiones" name="dimensions">
                    <group>
                        <field name="dimension_length"/>
                        <field name="dimension_width"/>
                    </group>
                    <group>
                        <field name="dimension_height"/>
                        <field name="dimension_diameter"/>
                    </group>
                    <group colspan="2">
                        <field name="dimension_display" readonly="1" 
                               class="oe_inline oe_read_only"
                               invisible="dimension_display == False"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extensión de la vista form de res.company -->
    <record id="view_company_form_reports_config" model="ir.ui.view">
        <field name="name">res.company.form.reports.config</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <!-- Añadir nueva página "Configuración Reportes" en el notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Configuración Reportes" name="reports_config">
                    
                    <!-- Logos Corporativos -->
                    <group string="Logos Corporativos" name="logos">
                        <group>
                            <field name="report_header_logo" widget="image" 
                                   class="oe_avatar"
                                   options="{'size': [200, 80]}"/>
                            <label for="report_header_logo" string="Logo Cabecera"/>
                            <div class="text-muted">
                                Recomendado: 200x80px PNG transparente
                            </div>
                        </group>
                        <group>
                            <field name="report_footer_logo" widget="image" 
                                   class="oe_avatar"
                                   options="{'size': [150, 60]}"/>
                            <label for="report_footer_logo" string="Logo Pie (Opcional)"/>
                            <div class="text-muted">
                                Recomendado: 150x60px PNG transparente
                            </div>
                        </group>
                    </group>

                    <!-- Disclaimers Legales -->
                    <group string="Avisos Legales" name="disclaimers">
                        <field name="report_quotation_disclaimer" 
                               widget="html"
                               placeholder="Texto legal para presupuestos..."/>
                        <field name="report_delivery_disclaimer" 
                               widget="html"
                               placeholder="Instrucciones para albaranes (Fase 2)..."/>
                        <field name="report_invoice_disclaimer" 
                               widget="html"
                               placeholder="Condiciones para facturas (Fase 2)..."/>
                    </group>

                    <!-- Configuración Técnica Py3o -->
                    <group string="Configuración Py3o" name="py3o_config">
                        <group>
                            <field name="py3o_conversion_timeout"/>
                        </group>
                        <group>
                            <field name="py3o_enable_cache"/>
                        </group>
                        <div class="text-muted" colspan="2">
                            <p><strong>Py3o</strong> es el motor de reportes para documentos complejos (presupuestos, albaranes).</p>
                            <ul>
                                <li><strong>Timeout:</strong> Tiempo máximo para convertir ODT→PDF (recomendado: 30s)</li>
                                <li><strong>Cache:</strong> Mantener plantillas en memoria para mayor velocidad</li>
                            </ul>
                        </div>
                    </group>

                </page>
            </xpath>
        </field>
    </record>
</odoo>
